# ARCBOS Board — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# In GitHub Actions, set these as Secrets and Variables (see DEPLOY.md).
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Notion integration token (read + write access to Board DB)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot token (from @BotFather)
TG_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Board database ID (32-char hex, no hyphens)
# Find it: open database in browser → URL → 32-char string before ?v=
BOARD_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion pacing ─────────────────────────────────────────────────────────────

# Milliseconds between Notion API requests (default: 500 — conservative)
# Lower = faster builds, higher risk of 429. Do not go below 300.
NOTION_GAP_MS=500

# Maximum retries for 5xx errors (default: 8)
NOTION_MAX_RETRIES=8

# Results per Notion API page (default: 100, max: 100)
NOTION_PAGE_SIZE=100

# ── Bot ───────────────────────────────────────────────────────────────────────

# Path to bot state file (persists last_update_id between runs)
BOT_STATE_FILE=/tmp/tg-bot-state.json

# Minimum seconds between board refreshes triggered by bot actions (default: 300)
# Set to 0 to refresh after every write (not recommended — high Actions usage)
BOARD_REFRESH_DEBOUNCE_SEC=300

# ── Board ─────────────────────────────────────────────────────────────────────

# Output directory for built HTML (default: out)
BOARD_OUT_DIR=out

# Custom domain for GitHub Pages CNAME file
BOARD_CNAME=board.arcbos.com

# Board page title
BOARD_TITLE=ARCBOS SnowBot — Project Board

# Board canonical domain (used in footer)
BOARD_DOMAIN=https://board.arcbos.com

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Development ───────────────────────────────────────────────────────────────

# Set to 1 for dry run — reads Notion but skips all writes and file output
DRY_RUN=0

# Set to 1 to fail prepare script on schema errors
PREPARE_FAIL_ON_ERROR=0
